{
  "manifest_version": 3,
  "name": "OpenTab",
  "short_name": "OpenTab",
  "description": "A simple local-first new tab launcher for favorite links.",
  "version": "0.1.0",
  "offline_enabled": true,
  "permissions": [
    "history"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
