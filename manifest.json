{
  "manifest_version": 3,
  "name": "OpenTab",
  "short_name": "OpenTab",
  "description": "A simple local-first new tab launcher for favorite links.",
  "version": "0.1.1",
  "offline_enabled": true,
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "history"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
